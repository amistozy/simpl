{
  "name": "simpl-language",
  "displayName": "Simpl Language Support",
  "description": "Syntax highlighting and language configuration for Simpl (.simpl).",
  "version": "0.1.0",
  "publisher": "amistozy",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "simpl",
    "language",
    "syntax"
  ],
  "scripts": {
    "package": "vsce package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "simpl",
        "aliases": [
          "Simpl",
          "simpl"
        ],
        "extensions": [
          ".simpl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "simpl",
        "scopeName": "source.simpl",
        "path": "./syntaxes/simpl.tmLanguage.json"
      }
    ]
  }
}
