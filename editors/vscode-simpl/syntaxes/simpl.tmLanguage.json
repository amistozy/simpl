{
  "name": "Simpl",
  "scopeName": "source.simpl",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#variants"
    },
    {
      "include": "#wildcards"
    },
    {
      "include": "#builtin-functions"
    },
    {
      "include": "#function-definition"
    },
    {
      "include": "#function-call"
    },
    {
      "include": "#member-access"
    },
    {
      "include": "#record-fields"
    },
    {
      "include": "#named-arguments"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    },
    {
      "include": "#identifiers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.simpl",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.simpl",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.simpl"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.simpl"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.simpl",
              "match": "\\\\(?:[\\\\\"ntr]|x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\})"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.negative.simpl",
          "match": "-\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.simpl",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.simpl",
          "match": "\\b(?:if|then|else|do|with|end|is|as|and|or|let|rec|fn)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.simpl",
          "match": "\\b(?:true|false)\\b"
        },
        {
          "name": "constant.language.null.simpl",
          "match": "\\bnil\\b"
        }
      ]
    },
    "variants": {
      "patterns": [
        {
          "name": "entity.name.type.variant.simpl",
          "match": "#[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    },
    "wildcards": {
      "patterns": [
        {
          "name": "variable.language.wildcard.simpl",
          "match": "(?<![A-Za-z0-9_])_(?![A-Za-z0-9_])"
        }
      ]
    },
    "builtin-functions": {
      "patterns": [
        {
          "name": "support.function.builtin.simpl",
          "match": "\\b(?:ref|say|map|filter|fold|length|max|min|sum)\\b(?=\\s*(?:\\(|:\\s*\\(|-(?=\\d)|\\s+(?:\\(|:\\s*\\(|-(?=\\d)|~|!|\\$|with\\b|fn\\b|if\\b|do\\b|let\\b|(?!(?:if|then|else|do|with|end|is|as|and|or|let|rec|fn|true|false|nil|ref|say|map|filter|fold|length|max|min|sum)\\b)[A-Za-z_][A-Za-z0-9_]*|\\d+|\"|#|\\[|\\{|true\\b|false\\b|nil\\b)))"
        }
      ]
    },
    "function-definition": {
      "patterns": [
        {
          "name": "meta.function.definition.simpl",
          "match": "\\b(?:let\\s+rec\\s+|let\\s+|and\\s+)([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*\\([^=\\n]*?(?<![:!<>=])=(?![=]))",
          "captures": {
            "1": {
              "name": "entity.name.function.simpl"
            }
          }
        },
        {
          "name": "meta.function.definition.simpl",
          "match": "([\\{\\(;]\\s*)([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*\\([^=\\n]*?(?<![:!<>=])=(?![=]))",
          "captures": {
            "2": {
              "name": "entity.name.function.simpl"
            }
          }
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "meta.function.call.simpl",
          "match": "\\b(?!(?:if|then|else|do|with|end|is|as|and|or|let|rec|fn|true|false|nil|ref|say|map|filter|fold|length|max|min|sum)\\b)([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*(?:\\(|:\\s*\\())",
          "captures": {
            "1": {
              "name": "entity.name.function.simpl"
            }
          }
        },
        {
          "name": "meta.function.call.simpl",
          "match": "\\b(?!(?:if|then|else|do|with|end|is|as|and|or|let|rec|fn|true|false|nil|ref|say|map|filter|fold|length|max|min|sum)\\b)([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s+(?:\\(|:\\s*\\(|-(?=\\d)|~|!|\\$|with\\b|fn\\b|if\\b|do\\b|let\\b|(?!(?:if|then|else|do|with|end|is|as|and|or|let|rec|fn|true|false|nil|ref|say|map|filter|fold|length|max|min|sum)\\b)[A-Za-z_][A-Za-z0-9_]*|\\d+|\"|#|\\[|\\{|true\\b|false\\b|nil\\b))",
          "captures": {
            "1": {
              "name": "entity.name.function.simpl"
            }
          }
        },
        {
          "name": "meta.function.call.member.simpl",
          "match": "(\\.)([A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*(?:\\(|:\\s*\\(|\\s+(?:\\(|:\\s*\\(|-(?=\\d)|~|!|\\$|with\\b|fn\\b|if\\b|do\\b|let\\b|(?!(?:if|then|else|do|with|end|is|as|and|or|let|rec|fn|true|false|nil|ref|say|map|filter|fold|length|max|min|sum)\\b)[A-Za-z_][A-Za-z0-9_]*|\\d+|\"|#|\\[|\\{|true\\b|false\\b|nil\\b)))",
          "captures": {
            "2": {
              "name": "entity.name.function.simpl"
            }
          }
        }
      ]
    },
    "member-access": {
      "patterns": [
        {
          "name": "variable.other.member.simpl",
          "match": "(\\.)([A-Za-z_][A-Za-z0-9_]*)\\b(?!\\s*(?:\\(|:\\s*\\(|\\s+(?:\\(|:\\s*\\(|-(?=\\d)|~|!|\\$|with\\b|fn\\b|if\\b|do\\b|let\\b|(?!(?:if|then|else|do|with|end|is|as|and|or|let|rec|fn|true|false|nil|ref|say|map|filter|fold|length|max|min|sum)\\b)[A-Za-z_][A-Za-z0-9_]*|\\d+|\"|#|\\[|\\{|true\\b|false\\b|nil\\b)))",
          "captures": {
            "2": {
              "name": "variable.other.property.simpl"
            }
          }
        }
      ]
    },
    "record-fields": {
      "patterns": [
        {
          "name": "meta.record.field.simpl",
          "match": "(\\{\\s*)([A-Za-z_][A-Za-z0-9_]*)(?=\\s*(?:=|[;}]))",
          "captures": {
            "2": {
              "name": "variable.other.property.simpl"
            }
          }
        },
        {
          "name": "meta.record.field.simpl",
          "match": "(;\\s*)([A-Za-z_][A-Za-z0-9_]*)(?=\\s*(?:=|[;}]))",
          "captures": {
            "2": {
              "name": "variable.other.property.simpl"
            }
          }
        }
      ]
    },
    "named-arguments": {
      "patterns": [
        {
          "name": "variable.parameter.simpl",
          "match": "(\\(\\s*)([A-Za-z_][A-Za-z0-9_]*)\\b\\s*(?==)",
          "captures": {
            "2": {
              "name": "variable.parameter.simpl"
            }
          }
        },
        {
          "name": "variable.parameter.simpl",
          "match": "(;\\s*)([A-Za-z_][A-Za-z0-9_]*)\\b\\s*(?==)",
          "captures": {
            "2": {
              "name": "variable.parameter.simpl"
            }
          }
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.assignment.simpl",
          "match": "(?<![|&])(?:\\+=|-=|\\*=|/=|%=|:=|&&=|\\|\\|=)"
        },
        {
          "name": "keyword.operator.comparison.simpl",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.symbol.simpl",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.arithmetic.simpl",
          "match": "\\+|-(?!\\d)|\\*|/|%|\\^|~|!|\\$"
        },
        {
          "name": "keyword.operator.assignment.simpl",
          "match": "="
        },
        {
          "name": "keyword.operator.other.simpl",
          "match": "\\.\\.|\\.|:"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.separator.simpl",
          "match": ";|\\|"
        },
        {
          "name": "punctuation.section.group.begin.simpl",
          "match": "[\\(\\[{]"
        },
        {
          "name": "punctuation.section.group.end.simpl",
          "match": "[\\)\\]}]"
        }
      ]
    },
    "identifiers": {
      "patterns": [
        {
          "name": "variable.other.readwrite.simpl",
          "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
        }
      ]
    }
  }
}
